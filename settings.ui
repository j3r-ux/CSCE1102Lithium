  <property name="styleSheet">
   <string notr="true">/* ===== APP BACKGROUND ===== */
QWidget {
    background-color: rgb(245, 247, 250);
    font-family: &quot;Segoe UI&quot;, Arial;
    font-size: 13px;
}

/* ===== TITLES ===== */
QLabel#titleLabel,
QLabel#chatTitleLabel,
QLabel#settingsTitleLabel {
    font-size: 26px;
    font-weight: bold;
    color: rgb(28, 113, 216);
    padding: 10px;
}

/* ===== NORMAL LABELS ===== */
QLabel {
    color: #333;
}

/* ===== INPUT FIELDS ===== */
QLineEdit {
    background-color: white;
    border: 2px solid #ccc;
    border-radius: 10px;
    padding: 6px;
    min-height: 28px;
}

QLineEdit:focus {
    border: 2px solid rgb(28, 113, 216);
}

/* ===== TEXT AREA (CHAT) ===== */
QTextEdit {
    background-color: white;
    border: 2px solid #ddd;
    border-radius: 10px;
    padding: 8px;
}

/* ===== LIST (ONLINE USERS) ===== */
QListWidget {
    background-color: white;
    border: 2px solid #ddd;
    border-radius: 10px;
    padding: 5px;
}

/* ===== BUTTONS ===== */
QPushButton {
    background-color: rgb(28, 113, 216);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 8px 16px;
    min-height: 32px;
    font-weight: 500;
}

/* Hover effect */
QPushButton:hover {
    background-color: rgb(53, 132, 228);
}

/* Click effect */
QPushButton:pressed {
    background-color: rgb(20, 90, 180);
}

/* ===== SECONDARY BUTTON (SIGN UP / BACK) ===== */
QPushButton#signupButton,
QPushButton#backButton {
    background-color: transparent;
    color: rgb(28, 113, 216);
    border: 2px solid rgb(28, 113, 216);
}

QPushButton#signupButton:hover,
QPushButton#backButton:hover {
    background-color: rgba(28, 113, 216, 40);
}

/* ===== DANGER BUTTON (DISCONNECT) ===== */
QPushButton#disconnectButton {
    background-color: rgb(200, 50, 50);
}

QPushButton#disconnectButton:hover {
    background-color: rgb(220, 70, 70);
}

/* ===== STATUS LABELS ===== */
QLabel#statusLabel,
QLabel#chatStatusLabel,
QLabel#settingsStatusLabel {
    font-weight: bold;
    font-size: 12px;
}

/* Login error */
QLabel#statusLabel {
    color: rgb(200, 0, 0);
}

/* Chat / settings success */
QLabel#chatStatusLabel,
QLabel#settingsStatusLabel {
    color: rgb(0, 140, 0);
}

/* ===== CHECKBOX ===== */
QCheckBox {
    spacing: 6px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
}

/* ===== GROUP BOX ===== */
QGroupBox {
    border: 2px solid #ddd;
    border-radius: 10px;
    margin-top: 10px;
    font-weight: bold;
}

QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
    color: rgb(28, 113, 216);
}</string>
